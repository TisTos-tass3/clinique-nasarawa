{% extends 'base.html.twig' %}
{% block title %}Laboratoire — Bons d'examens{% endblock %}

{% block body %}
<div class="container-fluid">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Laboratoire — Bons d'examens</h4>

        <form id="laboFilterForm" class="d-flex gap-2" method="get" action="{{ path('app_labo_bons') }}">
        <select id="statutSelect" name="statut" class="form-select form-select-sm" style="width: 220px;">
            {% for c in enum('App\\Enum\\StatutBonExamen').cases %}
            <option value="{{ c.value }}" {{ c.value == statut ? 'selected' : '' }}>{{ c.value }}</option>
            {% endfor %}
        </select>

        <input id="qInput" class="form-control form-control-sm" name="q" value="{{ q }}" placeholder="Patient / token">
        <button class="btn btn-sm btn-primary">Filtrer</button>
    </form>
  </div>

  <div class="card">
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-sm align-middle">
          <thead class="table-light">
            <tr>
              <th>#</th>
              <th>Patient</th>
              <th>Médecin</th>
              <th>Date</th>
              <th>Statut</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
          {% for b in bons %}
            <tr>
              <td>{{ b.id }}</td>
              <td class="fw-medium">{{ b.patient.nom }} {{ b.patient.prenom }}</td>
              <td>{{ b.medecin ? (b.medecin.nomComplet ?? b.medecin.nom) : '—' }}</td>
              <td>{{ b.dateDemande|date('d/m/Y H:i') }}</td>
              <td><span class="badge bg-light text-dark border">{{ b.statut.value }}</span></td>
              <td class="text-end">
                <a class="btn btn-sm btn-outline-secondary" target="_blank"
                   href="{{ path('app_labo_bon_print', {id: b.id}) }}">
                  <i class="ri-printer-line me-1"></i> Print
                </a>
                <a class="btn btn-sm btn-outline-primary" href="#bon-{{ b.id }}" data-bs-toggle="collapse">
                  Lignes
                </a>
              </td>
            </tr>

            <tr class="collapse" id="bon-{{ b.id }}">
              <td colspan="6">
                <div class="table-responsive">
                  <table class="table table-sm mb-0">
                    <thead class="table-light">
                      <tr>
                        <th>Examen</th>
                        <th>Urgence</th>
                        <th>Résultat</th>
                        <th class="text-end">Action</th>
                      </tr>
                    </thead>
                    <tbody>
                      {% for l in b.lignes %}
                        <tr>
                          <td class="fw-medium">{{ l.libelle }}</td>
                          <td>{% if l.urgence %}<span class="badge bg-danger">Urgent</span>{% else %}—{% endif %}</td>
                          <td>
                            {% if l.isResultatValide %}
                              <span class="text-success fw-semibold">OK</span>
                            {% else %}
                              <span class="text-muted">—</span>
                            {% endif %}
                          </td>
                          <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary js-open-ligne"
                                    data-bs-toggle="modal"
                                    data-bs-target="#ligneModal"
                                    data-url="{{ path('app_labo_ligne_modal', {id: l.id}) }}">
                              Saisir
                            </button>
                          </td>
                        </tr>
                      {% endfor %}
                    </tbody>
                  </table>
                </div>
              </td>
            </tr>
          {% else %}
            <tr><td colspan="6" class="text-center text-muted py-4">Aucun bon.</td></tr>
          {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="ligneModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-body p-4 text-center text-muted">Chargement...</div>
    </div>
  </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('click', async (e) => {
  const btn = e.target.closest('.js-open-ligne');
  if (!btn) return;

  const modalEl = document.querySelector('#ligneModal');
  const content = modalEl.querySelector('.modal-content');
  content.innerHTML = `<div class="modal-body p-4 text-center text-muted">Chargement...</div>`;

  const res = await fetch(btn.dataset.url, { headers: { 'X-Requested-With': 'XMLHttpRequest' }});
  content.innerHTML = await res.text();
});
</script>
<script>
document.addEventListener('submit', async (e) => {
  const form = e.target.closest('#ligneResultForm');
  if (!form) return;

  e.preventDefault();

  const res = await fetch(form.action, {
    method: 'POST',
    body: new FormData(form),
    headers: { 'X-Requested-With': 'XMLHttpRequest' }
  });

  // Debug utile si jamais ça casse
  const data = await res.json().catch(async () => {
    const txt = await res.text().catch(() => '');
    console.error('Réponse non JSON:', txt);
    return null;
  });

  if (!res.ok || !data?.success) {
    alert(data?.message ?? "Erreur lors de l'enregistrement.");
    return;
  }

  // ✅ fermer le modal
  const modalEl = document.querySelector('#ligneModal');
  bootstrap.Modal.getInstance(modalEl)?.hide();

  // ✅ recharger la page worklist
  window.location.href = window.location.pathname + window.location.search;
});
</script>
<script>
(function(){
  const form = document.getElementById('laboFilterForm');
  const statut = document.getElementById('statutSelect');

  if (statut && form) {
    statut.addEventListener('change', () => {
      form.submit();
    });
  }
})();
</script>
{% endblock %}