<div class="modal-header bg-light">
  <div>
    <h5 class="modal-title mb-0">Créer un bon d’examens</h5>
    <small class="text-muted">Patient : {{ patient.nom }} {{ patient.prenom }} — {{ patient.code }}</small>
  </div>
  <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">
  <form id="bonCreateForm" action="{{ path('app_consultation_labo_bon_new', {id: consultation.id}) }}" method="post">

    <div class="mb-2">
      <label class="form-label">Note (optionnel)</label>
      <textarea class="form-control" name="note" rows="2"></textarea>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-2">
      <h6 class="mb-0">Examens demandés</h6>
      <button type="button" class="btn btn-sm btn-outline-primary js-add-examen">
        <i class="ri-add-line me-1"></i> Ajouter
      </button>
    </div>

    <div id="bonExamens">
      <div class="input-group mb-2">
        <input class="form-control" name="examens[]" placeholder="Ex: NFS, CRP, Glycémie...">
        <button class="btn btn-outline-danger js-remove-examen" type="button"><i class="ri-delete-bin-line"></i></button>
      </div>
    </div>

    <div class="d-flex justify-content-end mt-3">
      <button class="btn btn-primary" type="submit">
        <i class="ri-save-line me-1"></i> Créer le bon
      </button>
    </div>
  </form>
</div>

<script>
(function(){
  const wrap = document.querySelector('#bonExamens');
  document.addEventListener('click', (e) => {
    if (e.target.closest('.js-add-examen')) {
      wrap.insertAdjacentHTML('beforeend', `
        <div class="input-group mb-2">
          <input class="form-control" name="examens[]" placeholder="Ex: NFS, CRP, Glycémie...">
          <button class="btn btn-outline-danger js-remove-examen" type="button"><i class="ri-delete-bin-line"></i></button>
        </div>
      `);
    }
    const rm = e.target.closest('.js-remove-examen');
    if (rm) rm.closest('.input-group')?.remove();
  });

  document.querySelector('#bonCreateForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;

    const res = await fetch(form.action, {
      method: 'POST',
      body: new FormData(form),
      headers: { 'X-Requested-With': 'XMLHttpRequest' }
    });

    const data = await res.json().catch(() => null);
    if (!res.ok || !data?.success) {
      alert(data?.message ?? 'Erreur création bon.');
      return;
    }
    location.reload();
  });
})();
</script>