{% if bons is defined and bons|length > 0 %}
  <div class="table-responsive">
    <table class="table table-sm align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>#</th>
          <th>Date</th>
          <th>Statut</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
      {% for b in bons %}
        <tr>
          <td>{{ b.id }}</td>
          <td>{{ b.dateDemande|date('d/m/Y H:i') }}</td>
          <td><span class="badge bg-light text-dark border">{{ b.statut.value }}</span></td>
          <td class="text-end">
            <a class="btn btn-sm btn-outline-secondary" target="_blank"
               href="{{ path('app_labo_bon_print', {id: b.id}) }}">
              <i class="ri-printer-line me-1"></i> Imprimer
            </a>
            <a class="btn btn-sm btn-outline-primary" target="_blank"
               href="{{ path('app_labo_bon_print_token', {token: b.token}) }}">
              QR/Token
            </a>
          </td>
        </tr>

        <tr>
          <td colspan="4" class="text-muted">
            {% for l in b.lignes %}
              <span class="badge bg-light text-dark border me-1 mb-1">
                {{ l.libelle }}{% if l.urgence %} (urgent){% endif %}
              </span>
            {% endfor %}
          </td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
{% else %}
  <div class="text-muted">Aucun bon d’examens créé pour cette consultation.</div>
{% endif %}