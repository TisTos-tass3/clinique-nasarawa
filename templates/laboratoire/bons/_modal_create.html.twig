<div class="modal-header bg-light">
  <div>
    <h5 class="modal-title mb-0">Demande d’examens</h5>
    <small class="text-muted">
      Patient : {{ patient.nom }} {{ patient.prenom }} — {{ patient.code }}
    </small>
  </div>
  <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">
  <form id="bonCreateForm" action="{{ path('app_consultation_labo_bon_modal', {id: consultation.id}) }}" method="post">

    <div class="mb-2">
      <label class="form-label">Note globale (optionnel)</label>
      <textarea class="form-control" name="note" rows="2"></textarea>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-2">
      <h6 class="mb-0">Examens</h6>
      <button type="button" class="btn btn-sm btn-outline-primary js-add-row">
        <i class="ri-add-line me-1"></i> Ajouter
      </button>
    </div>

    <div id="rows" data-index="1">
      <div class="card mb-2 js-row">
        <div class="card-body">
          <div class="row g-2 align-items-end">
            <div class="col-md-6">
              <label class="form-label">Libellé</label>
              <input class="form-control" name="examens[0][libelle]" placeholder="Ex: NFS, CRP, Glycémie...">
            </div>
            <div class="col-md-2">
              <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" name="examens[0][urgence]" value="1" id="u0">
                <label class="form-check-label" for="u0">Urgent</label>
              </div>
            </div>
            <div class="col-md-3">
              <label class="form-label">Note</label>
              <input class="form-control" name="examens[0][note]" placeholder="Optionnel">
            </div>
            <div class="col-md-1 text-end">
              <button type="button" class="btn btn-outline-danger js-remove-row" title="Supprimer">
                <i class="ri-delete-bin-line"></i>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="d-flex justify-content-end mt-3">
      <button class="btn btn-primary" type="submit">
        <i class="ri-save-line me-1"></i> Créer le bon
      </button>
    </div>
  </form>
</div>