{% extends 'base.html.twig' %}
{% block title %}Laboratoire — Examens{% endblock %}

{% block body %}
<div class="container-fluid">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Laboratoire — Examens</h4>
    <form class="d-flex gap-2" method="get" action="{{ path('app_laboratoire_examens') }}">
      <select name="statut" class="form-select form-select-sm" style="width: 200px;">
        <option value="demande" {{ statut == 'demande' ? 'selected' : '' }}>Demandés</option>
        <option value="preleve" {{ statut == 'preleve' ? 'selected' : '' }}>Prélevés</option>
        <option value="resultat_recu" {{ statut == 'resultat_recu' ? 'selected' : '' }}>Résultat reçu</option>
        <option value="annule" {{ statut == 'annule' ? 'selected' : '' }}>Annulés</option>
      </select>
      <input class="form-control form-control-sm" name="q" value="{{ q }}" placeholder="Patient / Examen">
      <button class="btn btn-sm btn-primary">Filtrer</button>
    </form>
  </div>

  <div class="card">
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-sm align-middle">
          <thead class="table-light">
            <tr>
              <th>#</th>
              <th>Patient</th>
              <th>Examen</th>
              <th>Urgence</th>
              <th>Statut</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
          {% for e in examens %}
            {% set patient = e.consultation.rendezVous ? e.consultation.rendezVous.patient : null %}
            <tr>
              <td>{{ e.id }}</td>
              <td>{{ patient ? (patient.nom ~ ' ' ~ patient.prenom) : '—' }}</td>
              <td class="fw-medium">{{ e.libelle }}</td>
              <td>{% if e.urgence %}<span class="badge bg-danger">Urgent</span>{% else %}—{% endif %}</td>
              <td><span class="badge bg-light text-dark border">{{ e.statut.value }}</span></td>
              <td class="text-end">
                {% if e.statut.value == 'demande' %}
                  <button class="btn btn-sm btn-outline-success js-prelever"
                          data-url="{{ path('app_laboratoire_examens_prelever', {id: e.id}) }}">
                    Prélever
                  </button>
                {% elseif e.statut.value == 'preleve' %}
                  <button class="btn btn-sm btn-outline-primary js-open-resultat"
                          data-bs-toggle="modal"
                          data-bs-target="#resultatModal"
                          data-url="{{ path('app_laboratoire_examens_resultat', {id: e.id}) }}">
                    Saisir résultat
                  </button>
                {% elseif e.statut.value == 'resultat_recu' %}
                  <span class="text-success fw-semibold">OK</span>
                {% endif %}
              </td>
            </tr>
          {% else %}
            <tr><td colspan="6" class="text-muted text-center py-4">Aucun examen.</td></tr>
          {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>

</div>

{# Modal résultat #}
<div class="modal fade" id="resultatModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-body p-4 text-center text-muted">Chargement...</div>
    </div>
  </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('click', async (e) => {
  // Prélever
  const pre = e.target.closest('.js-prelever');
  if (pre) {
    const res = await fetch(pre.dataset.url, {
      method: 'POST',
      headers: { 'X-Requested-With': 'XMLHttpRequest' }
    });
    const data = await res.json().catch(() => null);
    if (!res.ok || !data?.success) {
      alert(data?.message ?? 'Erreur.');
      return;
    }
    location.reload();
  }

  // Ouvrir modal résultat
  const open = e.target.closest('.js-open-resultat');
  if (open) {
    const modalEl = document.querySelector('#resultatModal');
    const content = modalEl.querySelector('.modal-content');
    content.innerHTML = `<div class="modal-body p-4 text-center text-muted">Chargement...</div>`;
    const r = await fetch(open.dataset.url, { headers: { 'X-Requested-With': 'XMLHttpRequest' }});
    content.innerHTML = await r.text();
  }
});
</script>
{% endblock %}