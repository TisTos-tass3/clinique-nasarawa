<div class="modal-header bg-light">
  <div>
    <h5 class="modal-title mb-0">Saisie résultat</h5>
    <small class="text-muted">Examen #{{ examen.id }} — {{ examen.libelle }}</small>
  </div>
  <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">
  <form id="resultatForm" action="{{ path('app_laboratoire_examens_resultat', {id: examen.id}) }}" method="post">
    <div class="mb-2">
      <label class="form-label">Résultat (texte)</label>
      <textarea class="form-control" name="resultatTexte" rows="8"
                placeholder="Ex: Hb: 12 g/dl, GB: ..., Conclusion: ...">{{ examen.resultatTexte }}</textarea>
    </div>

    <div class="row g-2">
      <div class="col-md-6">
        <label class="form-label">Prix examen (FCFA)</label>
        <input class="form-control" name="prixUnitaire" value="{{ examen.prixUnitaire ?? '' }}" placeholder="Ex: 7000">
        <div class="form-text">Optionnel : sert à la facturation quand RESULTAT_RECU.</div>
      </div>
      <div class="col-md-6 d-flex align-items-end justify-content-end">
        <button class="btn btn-primary js-save-resultat" type="submit">
          <i class="ri-save-line me-1"></i> Enregistrer & valider
        </button>
      </div>
    </div>
  </form>
</div>

<script>
document.querySelector('#resultatForm')?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const form = e.target;
  const res = await fetch(form.action, {
    method: 'POST',
    body: new FormData(form),
    headers: { 'X-Requested-With': 'XMLHttpRequest' }
  });
  const data = await res.json().catch(() => null);
  if (!res.ok || !data?.success) {
    alert(data?.message ?? "Erreur lors de l'enregistrement.");
    return;
  }
  location.reload();
});
</script>