<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <title>Bon d'examens - Consultation #{{ consultation.id }}</title>
  <style>
    body { font-family: Arial, sans-serif; color:#111; }
    .page { max-width: 820px; margin: 0 auto; padding: 22px; }
    .row { display:flex; justify-content:space-between; gap:16px; }
    .muted { color:#666; font-size: 12px; }
    h1 { font-size: 18px; margin:0; }
    h2 { font-size: 14px; margin: 14px 0 8px; }
    table { width:100%; border-collapse: collapse; margin-top: 10px; }
    th, td { border: 1px solid #ddd; padding: 8px; font-size: 13px; }
    th { background:#f3f4f6; text-align:left; }
    .badge { display:inline-block; padding: 3px 8px; border-radius: 999px; font-size: 12px; border:1px solid #ddd; background:#fafafa; }
    .no-print { margin-top: 14px; display:flex; gap:10px; justify-content:flex-end; }
    @media print { .no-print { display:none !important; } .page { padding: 0; } }
  </style>
</head>
<body>
<div class="page">

  <div class="row">
    <div>
      <h1>Bon d’examens (Laboratoire)</h1>
      <div class="muted">Consultation #{{ consultation.id }} — {{ "now"|date('d/m/Y H:i') }}</div>
    </div>
    <div style="text-align:right;">
      <div><strong>CLINIQUE MEDICALE NASSARAWA</strong></div>
      <div class="muted">Yantala Haut — Niamey</div>
      <div class="muted">Tél: … / BP: …</div>
    </div>
  </div>
  <img alt="QR Bon d'examens"
     src="{{ path('app_qr_consultation_bon_examens', {id: consultation.id}) }}"
     style="width: 120px; height: 120px; border:1px solid #ddd; padding:6px; border-radius:10px;">

  <h2>Patient</h2>
  <div class="row">
    <div>
      <div><span class="muted">Nom / Prénom :</span> <strong>{{ patient.nom ?? '' }} {{ patient.prenom ?? '' }}</strong></div>
      <div><span class="muted">Âge :</span> {{ patient.age ?? '—' }} <span class="muted">Sexe :</span> {{ patient.sexe ?? '—' }}</div>
    </div>
    <div style="text-align:right;">
      <div><span class="muted">Médecin :</span> <strong>{{ medecin.nomComplet ?? medecin.nom ?? '—' }}</strong></div>
      <div><span class="muted">Rendez-vous :</span> {{ consultation.rendezVous ? '#' ~ consultation.rendezVous.id : '—' }}</div>
    </div>
  </div>

  <h2>Examens demandés</h2>
  <table>
    <thead>
      <tr>
        <th>Libellé</th>
        <th>Urgence</th>
        <th>Note</th>
      </tr>
    </thead>
    <tbody>
    {% for ex in examens %}
      {% if ex.statut.value != 'annule' %}
        <tr>
          <td>{{ ex.libelle }}</td>
          <td>{% if ex.urgence %}<span class="badge">URGENT</span>{% else %}—{% endif %}</td>
          <td>{{ ex.note ?: '—' }}</td>
        </tr>
      {% endif %}
    {% else %}
      <tr><td colspan="3" class="muted">Aucun examen demandé.</td></tr>
    {% endfor %}
    </tbody>
  </table>

  <div style="margin-top:16px;" class="row">
    <div>
      <div><span class="muted">Date :</span> {{ "now"|date('d/m/Y') }}</div>
    </div>
    <div style="text-align:right;">
      <div><span class="muted">Signature :</span> _______________________</div>
    </div>
  </div>

  <div class="no-print">
    <button onclick="window.print()">Imprimer</button>
    <button onclick="window.close()">Fermer</button>
  </div>

</div>
</body>
</html>