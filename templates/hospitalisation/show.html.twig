{% extends 'base.html.twig' %}

{% block title %}Hospitalisation #{{ hospitalisation.id }}{% endblock %}

{% block body %}
<style>
  .hs-wrap{ max-width: 1100px; margin: 0 auto; }
  .hs-card{
    border: 1px solid rgba(0,0,0,.06);
    border-radius: 16px;
  }
  .hs-card .card-header{
    background:#fff;
    border-bottom:1px solid rgba(0,0,0,.06);
    border-top-left-radius:16px;
    border-top-right-radius:16px;
  }
  .hs-kv{
    display:grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px 16px;
  }
  @media (max-width: 768px){
    .hs-kv{ grid-template-columns: 1fr; }
  }
  .hs-field{
    border: 1px solid rgba(0,0,0,.06);
    border-radius: 14px;
    padding: 12px 12px;
    background:#fff;
  }
  .hs-label{
    font-size: 12px;
    color:#6b7280;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .04em;
    margin-bottom: 6px;
  }
  .hs-value{
    font-size: 14px;
    font-weight: 650;
    color:#111827;
    line-height: 1.35;
    word-break: break-word;
  }
  .hs-section{
    border: 1px solid rgba(0,0,0,.06);
    border-radius: 16px;
    background:#fff;
    padding: 14px;
  }
  .hs-section-title{
    font-weight: 900;
    font-size: 14px;
    color:#111827;
    margin-bottom: 10px;
    display:flex;
    align-items:center;
    gap:8px;
  }
  .hs-text{
    white-space: pre-line;
    color:#111827;
    font-size: 14px;
    line-height: 1.5;
  }
  .hs-muted{ color:#6b7280; }
  .badge-soft{
    border: 1px solid rgba(0,0,0,.08);
    padding: .45rem .65rem;
    border-radius: 999px;
    font-weight: 800;
  }
</style>

{# Helpers #}
{% set statut = hospitalisation.statut ? (hospitalisation.statut.value ?? hospitalisation.statut.name ?? hospitalisation.statut) : '—' %}

{# Badge selon statut (adapte si tes valeurs diffèrent) #}
{% set badgeClass =
  statut in ['TERMINE','SORTIE','CLOTURE','CLOTUREE'] ? 'bg-success-subtle text-success badge-soft' :
  (statut in ['EN_COURS','HOSPITALISE','ACTIVE'] ? 'bg-warning-subtle text-warning badge-soft' :
  (statut in ['ANNULE','ANNULEE'] ? 'bg-danger-subtle text-danger badge-soft' :
  'bg-light text-muted badge-soft'))
%}

{# Dossier label #}
{% set dossierLabel = '—' %}
{% if hospitalisation.dossierMedical %}
  {% set d = hospitalisation.dossierMedical %}
  {% set dossierLabel = d.numeroDossier ?? ('Dossier #' ~ d.id) %}
{% endif %}

{# Médecin label #}
{% set medecinLabel = '—' %}
{% if hospitalisation.medecinReferent %}
  {% set m = hospitalisation.medecinReferent %}
  {# {% set medecinLabel = m.nomComplet ?? ((m.nom ?? '') ~ ' ' ~ (m.prenom ?? ''))|trim ?? ('Utilisateur #' ~ m.id) %} #}
{% endif %}

{# Patient label (si tu as une relation depuis dossierMedical) #}
{% set patientLabel = '—' %}
{% if hospitalisation.dossierMedical and hospitalisation.dossierMedical.patient is defined and hospitalisation.dossierMedical.patient %}
  {% set p = hospitalisation.dossierMedical.patient %}
  {% set patientLabel = ((p.nom ?? '') ~ ' ' ~ (p.prenom ?? ''))|trim %}
{% endif %}

{# Dates #}
{% set admission = hospitalisation.dateAdmission ? hospitalisation.dateAdmission|date('d/m/Y H:i') : '—' %}
{% set sortie = hospitalisation.dateSortie ? hospitalisation.dateSortie|date('d/m/Y H:i') : '—' %}

<div class="hs-wrap">
  <div class="card hs-card shadow-sm border-0">
    <div class="card-header py-3">
      <div class="d-flex flex-wrap justify-content-between align-items-start gap-2">
        <div>
          <h5 class="mb-0 fw-semibold">
            <i class="fa fa-procedures me-2 text-primary"></i>
            Hospitalisation #{{ hospitalisation.id }}
          </h5>
          <div class="text-muted small">
            Fiche d’hospitalisation — informations administratives & médicales
          </div>
        </div>

        <div class="d-flex gap-2 align-items-center">
          <span class="{{ badgeClass }}">{{ statut }}</span>

          <a href="{{ path('app_hospitalisation_index') }}" class="btn btn-light border">
            <i class="fa fa-arrow-left me-1"></i> Retour
          </a>

          {# Si tu utilises un edit en modal AJAX, mets le bouton comme ceci #}
          <button type="button"
                  class="btn btn-outline-primary js-edit-hospitalisation"
                  data-bs-toggle="modal"
                  data-bs-target="#editHospitalisationModal"
                  data-url="{{ path('app_hospitalisation_edit', {'id': hospitalisation.id}) }}">
            <i class="fa fa-pen me-1"></i> Modifier
          </button>

          <button type="button" class="btn btn-primary" onclick="window.print()">
            <i class="fa fa-print me-1"></i> Imprimer
          </button>
        </div>
      </div>
    </div>

    <div class="card-body">
      {# ====== Bloc infos clés ====== #}
      <div class="hs-kv mb-3">
        <div class="hs-field">
          <div class="hs-label">Dossier médical</div>
          <div class="hs-value">{{ dossierLabel }}</div>
          {% if patientLabel != '—' %}
            <div class="hs-muted small mt-1">Patient : {{ patientLabel }}</div>
          {% endif %}
        </div>

        <div class="hs-field">
          <div class="hs-label">Médecin référent</div>
          <div class="hs-value">{{ medecinLabel }}</div>
        </div>

        <div class="hs-field">
          <div class="hs-label">Date d’admission</div>
          <div class="hs-value">{{ admission }}</div>
        </div>

        <div class="hs-field">
          <div class="hs-label">Date de sortie</div>
          <div class="hs-value">{{ sortie }}</div>
          {% if hospitalisation.dateSortie is empty %}
            <div class="hs-muted small mt-1">Patient actuellement hospitalisé.</div>
          {% endif %}
        </div>
      </div>

      {# ====== Sections texte ====== #}
      <div class="row g-3">
        <div class="col-12">
          <div class="hs-section">
            <div class="hs-section-title">
              <i class="fa fa-clipboard-list text-primary"></i> Motif d’admission
            </div>
            <div class="hs-text">{{ hospitalisation.motifAdmission ?: '—' }}</div>
          </div>
        </div>

        <div class="col-12 col-lg-6">
          <div class="hs-section h-100">
            <div class="hs-section-title">
              <i class="fa fa-notes-medical text-primary"></i> Histoire de la maladie
            </div>
            <div class="hs-text">{{ hospitalisation.histoireMaladie ?: '—' }}</div>
          </div>
        </div>

        <div class="col-12 col-lg-6">
          <div class="hs-section h-100">
            <div class="hs-section-title">
              <i class="fa fa-chart-line text-primary"></i> Évolution
            </div>
            <div class="hs-text">{{ hospitalisation.evolution ?: '—' }}</div>
          </div>
        </div>

        <div class="col-12">
          <div class="hs-section">
            <div class="hs-section-title">
              <i class="fa fa-check-circle text-primary"></i> Conclusion
            </div>
            <div class="hs-text">{{ hospitalisation.conclusion ?: '—' }}</div>
          </div>
        </div>

        {# ====== Examens ====== #}
        <div class="col-12">
          <div class="hs-section">
            <div class="hs-section-title">
              <i class="fa fa-stethoscope text-primary"></i> Examens
            </div>

            <div class="row g-3">
              <div class="col-12 col-md-6">
                <div class="hs-field">
                  <div class="hs-label">Examen clinique</div>
                  <div class="hs-value">
                    {% if hospitalisation.examenClinique %}
                      #{{ hospitalisation.examenClinique.id }}
                    {% else %}
                      —
                    {% endif %}
                  </div>
                </div>
              </div>

              <div class="col-12 col-md-6">
                <div class="hs-field">
                  <div class="hs-label">Examen neurologique</div>
                  <div class="hs-value">
                    {% if hospitalisation.examenNeurologique %}
                      #{{ hospitalisation.examenNeurologique.id }}
                    {% else %}
                      —
                    {% endif %}
                  </div>
                </div>
              </div>

              {# Si tu as des pages show pour ces entités, tu peux activer les liens #}
              {# 
              <a href="{{ path('app_examen_clinique_show', {'id': hospitalisation.examenClinique.id}) }}">Voir</a>
              #}
            </div>
          </div>
        </div>

      </div>
    </div>

    <div class="card-footer bg-white border-0 pt-0">
      <div class="text-muted small">
        Créé le : {{ hospitalisation.createdAt ? hospitalisation.createdAt|date('d/m/Y H:i') : '—' }}
        {# — Mis à jour le : {{ hospitalisation.updatedAt ? hospitalisation.updatedAt|date('d/m/Y H:i') : '—' }} #}
      </div>
    </div>
  </div>
</div>

{# =========================
   MODAL EDIT (si besoin)
   (tu peux reprendre ton pattern AJAX)
========================= #}
<div class="modal fade" id="editHospitalisationModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable modal-dialog-centered">
    <div class="modal-content border-0 shadow">
      <div class="modal-header bg-white">
        <h5 class="modal-title fw-semibold">
          <i class="fa fa-pen me-2 text-primary"></i> Modifier hospitalisation
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
      </div>
      <div class="modal-body">
        <div class="text-center py-4" id="editHospLoader">
          <div class="spinner-border" role="status" aria-hidden="true"></div>
          <div class="mt-2 text-muted small">Chargement du formulaire…</div>
        </div>
        <div id="editHospBody" class="d-none"></div>
      </div>
      <div class="modal-footer bg-white">
        <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Fermer</button>
      </div>
    </div>
  </div>
</div>

{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script>
    // Mini loader AJAX (même logique que factures)
    (function(){
      const editModalEl = document.getElementById('editHospitalisationModal');
      const loader = document.getElementById('editHospLoader');
      const body = document.getElementById('editHospBody');

      const xhrHeaders = { 'X-Requested-With': 'XMLHttpRequest' };

      function setLoading(loading=true){
        if(loading){
          loader.classList.remove('d-none');
          body.classList.add('d-none');
          body.innerHTML = '';
        }else{
          loader.classList.add('d-none');
          body.classList.remove('d-none');
        }
      }

      async function openForm(url){
        setLoading(true);
        const res = await fetch(url, { headers: xhrHeaders });
        if(!res.ok) throw new Error('HTTP '+res.status);
        body.innerHTML = await res.text();
        setLoading(false);

        const form = body.querySelector('form');
        if(!form) return;

        if(form.dataset.bound === '1') return;
        form.dataset.bound = '1';

        form.addEventListener('submit', async (ev) => {
          ev.preventDefault();
          const fd = new FormData(form);
          const submitRes = await fetch(form.action, { method: 'POST', body: fd, headers: xhrHeaders });
          const ct = submitRes.headers.get('content-type') || '';
          if(ct.includes('application/json')){
            const json = await submitRes.json();
            if(json.success){
              bootstrap.Modal.getInstance(editModalEl)?.hide();
              window.location.reload();
              return;
            }
          }
          body.innerHTML = await submitRes.text();
          form.dataset.bound = '0';
        });
      }

      document.addEventListener('click', (e)=>{
        const btn = e.target.closest('.js-edit-hospitalisation');
        if(!btn) return;
        const url = btn.getAttribute('data-url');
        if(!url) return;
        openForm(url).catch(()=> {
          setLoading(false);
          body.innerHTML = `<div class="alert alert-danger mb-0">Impossible de charger le formulaire.</div>`;
        });
      });

      editModalEl?.addEventListener('hidden.bs.modal', ()=> setLoading(true));
    })();
  </script>
{% endblock %}