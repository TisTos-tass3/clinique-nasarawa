{% extends 'base.html.twig' %}

{% block title %}Consultation #{{ consultation.id }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {% set rdv = consultation.rendezVous|default(null) %}
    {% set patient = rdv ? (rdv.patient|default(null)) : null %}
    {% set st = consultation.statut is defined and consultation.statut ? (consultation.statut.name ?? consultation.statut.value ?? '') : '' %}
    {% set badgeClass =
        st in ['EN_COURS'] ? 'bg-primary' :
        st in ['BROUILLON'] ? 'bg-secondary' :
        st in ['CLOTURE', 'CLOTUREE'] ? 'bg-success' :
        st in ['ANNULE', 'ANNULEE'] ? 'bg-danger' :
        'bg-dark'
    %}
    {% set locked = st in ['CLOTURE', 'CLOTUREE', 'ANNULE', 'ANNULEE'] %}

    {# ===================== HEADER ===================== #}
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
        <div>
            <h3 class="mb-1">
                Consultation <span class="text-muted">#{{ consultation.id }}</span>
            </h3>

            <div class="text-muted small">
                {% if rdv %}
                    RDV #{{ rdv.id }}
                    {% if rdv.dateHeure is defined and rdv.dateHeure %}
                        — {{ rdv.dateHeure|date('Y-m-d H:i') }}
                    {% endif %}
                {% endif %}
            </div>

            <div class="mt-2 d-flex flex-wrap gap-2">
                <span class="badge {{ badgeClass }}">{{ st ?: 'N/A' }}</span>

                {% if consultation.medecin is defined and consultation.medecin %}
                    <span class="badge bg-light text-dark border">
                        Médecin :
                        {{ consultation.medecin.nomComplet|default(((consultation.medecin.nom|default('') ~ ' ' ~ consultation.medecin.prenom|default(''))|trim))|default(consultation.medecin.id) }}
                    </span>
                {% endif %}

                {% if patient %}
                    <span class="badge bg-light text-dark border">
                        Patient :
                        {{ patient.nomComplet|default(((patient.nom|default('') ~ ' ' ~ patient.prenom|default(''))|trim))|default(patient.id) }}
                    </span>
                {% endif %}
            </div>
        </div>

        {# ===================== ACTIONS ===================== #}
        <div class="d-flex flex-wrap gap-2">
            <a href="{{ path('app_consultation_index') }}" class="btn btn-outline-secondary">
                <i class="fa fa-arrow-left me-1"></i> Retour
            </a>

            <button type="button"
                    class="btn btn-primary js-edit-consultation {{ locked ? 'disabled' : '' }}"
                    title="Saisie médicale"
                    data-bs-toggle="modal"
                    data-bs-target="#editConsultationModal"
                    data-url="{{ path('app_consultation_medical_edit', {'id': consultation.id}) }}"
                    {{ locked ? 'disabled' : '' }}>
                <i class="fa fa-pen me-1"></i> Saisie médicale
            </button>

            <button type="button"
                    class="btn btn-outline-primary js-open-prescription"
                    data-bs-toggle="modal"
                    data-bs-target="#prescriptionModal"
                    data-url="{{ path('app_consultation_prescription_modal', {id: consultation.id}) }}">
                <i class="ri-file-text-line me-1"></i> Prescription
            </button>

            {{ include('consultation/_delete_form.html.twig') }}
        </div>
    </div>

    {# ===================== PRESTATIONS PRESCRITES ===================== #}
    <div class="card shadow-sm border-0 rounded-4 mt-4">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-0">Prestations prescrites</h5>
                <small class="text-muted">Actes, examens et consommables demandés par le médecin</small>
            </div>

            <button type="button"
                    class="btn btn-primary btn-sm js-add-prestation"
                    data-bs-toggle="modal"
                    data-bs-target="#prestationModal"
                    data-url="{{ path('app_prescription_prestation_new', {id: consultation.id}) }}">
                <i class="ri-add-line me-1"></i> Ajouter
            </button>
        </div>

        <div class="card-body">
            {% if consultation.prescriptionsPrestations is defined and consultation.prescriptionsPrestations|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Prestation</th>
                                <th>Catégorie</th>
                                <th>Quantité</th>
                                <th>Instructions</th>
                                <th>Statut</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for p in consultation.prescriptionsPrestations %}
                            <tr>
                                <td class="fw-semibold">
                                    {{ p.tarifPrestation.libelle|default('-') }}
                                </td>
                                <td>
                                    <span class="badge bg-secondary-subtle text-secondary">
                                        {{ p.tarifPrestation.categorie.value|default('-')|replace({'_':' '})|title }}
                                    </span>
                                </td>
                                <td>{{ p.quantite|default(1) }}</td>
                                <td>{{ p.instructions ?: '-' }}</td>
                                <td>
                                    {% if p.statut.value == 'prescrit' %}
                                        <span class="badge bg-warning-subtle text-warning">Prescrit</span>
                                    {% elseif p.statut.value == 'facture' %}
                                        <span class="badge bg-info-subtle text-info">Facturé</span>
                                    {% elseif p.statut.value == 'paye' %}
                                        <span class="badge bg-primary-subtle text-primary">Payé</span>
                                    {% elseif p.statut.value == 'en_cours' %}
                                        <span class="badge bg-secondary-subtle text-secondary">En cours</span>
                                    {% elseif p.statut.value == 'realise' %}
                                        <span class="badge bg-success-subtle text-success">Réalisé</span>
                                    {% elseif p.statut.value == 'annule' %}
                                        <span class="badge bg-danger-subtle text-danger">Annulé</span>
                                    {% else %}
                                        <span class="badge bg-light text-dark">{{ p.statut.value }}</span>
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    <button type="button"
                                            class="btn btn-sm btn-outline-primary js-edit-prestation"
                                            title="Modifier"
                                            data-bs-toggle="modal"
                                            data-bs-target="#prestationModal"
                                            data-url="{{ path('app_prescription_prestation_edit', {id: p.id}) }}">
                                        <i class="ri-pencil-line"></i>
                                    </button>

                                    <form method="post"
                                          action="{{ path('app_prescription_prestation_delete', {id: p.id}) }}"
                                          class="d-inline"
                                          onsubmit="return confirm('Supprimer cette prestation ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_prestation_' ~ p.id) }}">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer">
                                            <i class="ri-delete-bin-line"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center py-4">
                    <i class="ri-file-list-3-line fs-1 text-muted"></i>
                    <p class="text-muted mb-0 mt-2">Aucune prestation prescrite pour cette consultation.</p>
                </div>
            {% endif %}
        </div>
    </div>

    {# ===================== KPI CARDS (Constantes) ===================== #}
    <div class="row g-3 mb-4 mt-1">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Poids</div>
                    <div class="fs-4 fw-semibold">
                        {{ consultation.poids ?? '-' }} <span class="text-muted fs-6">kg</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Taille</div>
                    <div class="fs-4 fw-semibold">
                        {{ consultation.taille ?? '-' }} <span class="text-muted fs-6">cm</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Température</div>
                    <div class="fs-4 fw-semibold">
                        {{ consultation.temperature ?? '-' }} <span class="text-muted fs-6">°C</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Fréquence cardiaque</div>
                    <div class="fs-4 fw-semibold">
                        {{ consultation.frequenceCardiaque ?? '-' }} <span class="text-muted fs-6">bpm</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ===================== TABS ===================== #}
    <ul class="nav nav-tabs" id="consultTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active"
                    id="tab-clinique"
                    data-bs-toggle="tab"
                    data-bs-target="#pane-clinique"
                    type="button"
                    role="tab">
                Clinique
            </button>
        </li>

        <li class="nav-item" role="presentation">
            <button class="nav-link"
                    id="tab-prescriptions"
                    data-bs-toggle="tab"
                    data-bs-target="#pane-prescriptions"
                    type="button"
                    role="tab">
                Prescriptions
            </button>
        </li>
    </ul>

    <div class="tab-content border border-top-0 rounded-bottom p-3" id="consultTabsContent">
        {# ========== CLINIQUE ========== #}
        <div class="tab-pane fade show active" id="pane-clinique" role="tabpanel">
            <div class="row g-3">
                <div class="col-12 col-lg-6">
                    <div class="card h-100">
                        <div class="card-header fw-semibold">Motif & Histoire</div>
                        <div class="card-body">
                            <div class="mb-3">
                                <div class="text-muted small">Motifs</div>
                                <div>{{ consultation.motifs ?? '-' }}</div>
                            </div>

                            <div>
                                <div class="text-muted small">Histoire / Anamnèse</div>
                                <div>{{ consultation.histoire ?? '-' }}</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-lg-6">
                    <div class="card h-100">
                        <div class="card-header fw-semibold">Examen & Diagnostic</div>
                        <div class="card-body">
                            <div class="mb-3">
                                <div class="text-muted small">Examen clinique</div>
                                <div>{{ consultation.examenClinique ?? '-' }}</div>
                            </div>

                            <div class="mb-3">
                                <div class="text-muted small">Tension artérielle</div>
                                <div>{{ consultation.tensionArterielle ?? '-' }}</div>
                            </div>

                            <div class="mb-3">
                                <div class="text-muted small">Diagnostic</div>
                                <div>{{ consultation.diagnostic ?? '-' }}</div>
                            </div>

                            <div>
                                <div class="text-muted small">CIM10</div>
                                <div>
                                    {% if consultation.cim10 is defined and consultation.cim10 %}
                                        {{ consultation.cim10 }}
                                    {% else %}
                                        -
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="card">
                        <div class="card-header fw-semibold">Conduite à tenir</div>
                        <div class="card-body">
                            {{ consultation.conduiteATenir ?? '-' }}
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="text-muted small">
                        Créée : {{ consultation.createdAt ? consultation.createdAt|date('Y-m-d H:i') : '-' }}
                        — Modifiée : {{ consultation.modifiedAt ? consultation.modifiedAt|date('Y-m-d H:i') : '-' }}
                    </div>
                </div>
            </div>
        </div>

        {# ========== PRESCRIPTIONS ========== #}
        <div class="tab-pane fade" id="pane-prescriptions" role="tabpanel">
            <div class="card mb-3 border-0 shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">Prescription</h6>
                    <span class="badge bg-light text-dark border">
                        {{ consultation.prescriptions is defined ? consultation.prescriptions|length : 0 }} document(s)
                    </span>
                </div>
                <div class="card-body" id="prescriptionSummary">
                    {% include 'prescription/_summary.html.twig' with { consultation: consultation } %}
                </div>
            </div>

            {% if consultation.prescriptions is defined and consultation.prescriptions|length > 0 %}
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                        <tr>
                            <th>#</th>
                            <th>Date</th>
                            <th>Commentaire</th>
                            <th class="text-end">Lignes</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for p in consultation.prescriptions %}
                            <tr>
                                <td>{{ p.id }}</td>
                                <td>{{ p.datePrescription is defined and p.datePrescription ? p.datePrescription|date('Y-m-d H:i') : '-' }}</td>
                                <td>{{ p.commentaire ?? '-' }}</td>
                                <td class="text-end">
                                    {{ p.lignes is defined ? p.lignes|length : 0 }}
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-muted">Aucune prescription pour le moment.</div>
            {% endif %}
        </div>
    </div>
</div>

{# =========================
   MODAL EDIT CONSULTATION (AJAX)
========================= #}
<div class="modal fade" id="editConsultationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Saisie médicale</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="editConsultationModalBody">
                <div class="text-center py-3">Chargement...</div>
            </div>
        </div>
    </div>
</div>

{# =========================
   MODAL PRESTATION (AJAX)
========================= #}
<div class="modal fade" id="prestationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" id="prestationModalContent">
            <div class="modal-body text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-3 mb-0">Chargement...</p>
            </div>
        </div>
    </div>
</div>

{# =========================
   MODAL RESUME PRESCRIPTION (AJAX)
========================= #}
<div class="modal fade" id="prescriptionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-body p-4 text-center text-muted">Chargement...</div>
        </div>
    </div>
</div>
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script>
(() => {
    const consultationModalEl = document.getElementById('editConsultationModal');
    const consultationLoader = document.getElementById('editConsultationLoader');
    const consultationBody = document.getElementById('editConsultationModalBody');

    let consultationCurrentUrl = null;

    function consultationSetLoading() {
        if (!consultationLoader || !consultationBody) return;
        consultationLoader.classList.remove('d-none');
        consultationBody.classList.add('d-none');
        consultationBody.innerHTML = '';
    }

    function consultationShowError(message) {
        if (!consultationLoader || !consultationBody) return;
        consultationLoader.classList.add('d-none');
        consultationBody.classList.remove('d-none');
        consultationBody.innerHTML = `
            <div class="alert alert-danger d-flex align-items-start gap-2 mb-0" role="alert">
                <i class="fa fa-exclamation-triangle mt-1"></i>
                <div>
                    <div class="fw-semibold">Erreur</div>
                    <div class="small">${message || 'Impossible de charger le formulaire.'}</div>
                </div>
            </div>
        `;
    }

    function consultationFocusFirstField() {
        if (!consultationBody) return;
        const first = consultationBody.querySelector('.is-invalid, input, select, textarea');
        if (first) first.focus();
    }

    function openAccordionForErrors() {
        if (!consultationBody) return;

        const invalidField = consultationBody.querySelector('.is-invalid');
        if (!invalidField) return;

        const collapse = invalidField.closest('.accordion-collapse');
        if (!collapse) return;

        consultationBody.querySelectorAll('.accordion-collapse').forEach(el => {
            if (el !== collapse) {
                bootstrap.Collapse.getOrCreateInstance(el, { toggle: false }).hide();
            }
        });

        bootstrap.Collapse.getOrCreateInstance(collapse, { toggle: false }).show();

        const trigger = consultationBody.querySelector(`[data-bs-target="#${collapse.id}"]`);
        if (trigger) {
            consultationBody.querySelectorAll('.accordion-button').forEach(btn => {
                btn.classList.add('collapsed');
                btn.setAttribute('aria-expanded', 'false');
            });

            trigger.classList.remove('collapsed');
            trigger.setAttribute('aria-expanded', 'true');
        }
    }

    function afterConsultationHtmlInjected() {
        consultationLoader.classList.add('d-none');
        consultationBody.classList.remove('d-none');
        openAccordionForErrors();
        consultationFocusFirstField();
        bindConsultationForm();
    }

    function bindConsultationForm() {
        if (!consultationBody) return;

        const form = consultationBody.querySelector('#medicalForm');
        if (!form || form.dataset.bound === '1') return;

        form.dataset.bound = '1';

        form.addEventListener('submit', async function (e) {
            e.preventDefault();

            const submitButtons = form.querySelectorAll('button[type="submit"]');
            const originals = Array.from(submitButtons).map(btn => btn.innerHTML);

            submitButtons.forEach((btn, index) => {
                btn.disabled = true;
                if (index === 0) {
                    btn.innerHTML = `<span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span> Enregistrement...`;
                }
            });

            try {
                const response = await fetch(form.action || consultationCurrentUrl, {
                    method: (form.method || 'POST').toUpperCase(),
                    body: new FormData(form),
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                const contentType = response.headers.get('content-type') || '';

                if (contentType.includes('application/json')) {
                    const data = await response.json();

                    if (data.success) {
                        const modalInstance = bootstrap.Modal.getInstance(consultationModalEl);
                        modalInstance?.hide();
                        return;
                    }

                    consultationShowError(data.message || "Une erreur est survenue lors de l'enregistrement.");
                    return;
                }

                const html = await response.text();
                consultationBody.innerHTML = html;
                afterConsultationHtmlInjected();
            } catch (error) {
                console.error('Erreur soumission consultation:', error);
                consultationShowError("Une erreur est survenue lors de l'enregistrement.");
            } finally {
                submitButtons.forEach((btn, index) => {
                    btn.disabled = false;
                    btn.innerHTML = originals[index];
                });
            }
        });
    }

    async function loadConsultationForm(url) {
        consultationCurrentUrl = url;
        consultationSetLoading();

        try {
            const response = await fetch(url, {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            });

            if (!response.ok) {
                throw new Error(`HTTP ${response.status}`);
            }

            const html = await response.text();
            consultationBody.innerHTML = html;
            afterConsultationHtmlInjected();
        } catch (error) {
            console.error('Erreur chargement consultation:', error);
            consultationShowError("Impossible de charger le formulaire.");
        }
    }

    document.addEventListener('click', function (e) {
        const btn = e.target.closest('.js-edit-consultation');
        if (!btn) return;

        if (btn.classList.contains('disabled') || btn.hasAttribute('disabled')) {
            e.preventDefault();
            return;
        }

        const url = btn.dataset.url;
        if (!url) return;

        loadConsultationForm(url);
    });

    consultationModalEl?.addEventListener('hidden.bs.modal', function () {
        consultationCurrentUrl = null;
        consultationSetLoading();
    });
})();
</script>
{% endblock %}